{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/favicon\\.ico", "dest": "/favicon.ico" },
    { "src": "/favicon\\.svg", "dest": "/favicon.svg" },
    { "src": "/pop/favicon\\.ico", "dest": "/pop/favicon.ico" },
    { "src": "/pop/favicon\\.svg", "dest": "/pop/favicon.svg" },
    { "src": "/pdv/favicon\\.ico", "dest": "/pdv/favicon.ico" },
    { "src": "/pdv/favicon\\.svg", "dest": "/pdv/favicon.svg" },
    { "src": "/ptc/favicon\\.ico", "dest": "/ptc/favicon.ico" },
    { "src": "/ptc/favicon\\.svg", "dest": "/ptc/favicon.svg" },
    { "src": "/pas/favicon\\.ico", "dest": "/pas/favicon.ico" },
    { "src": "/pas/favicon\\.svg", "dest": "/pas/favicon.svg" },
    { "src": "/rastreio/favicon\\.ico", "dest": "/rastreio/favicon.ico" },
    { "src": "/rastreio/favicon\\.svg", "dest": "/rastreio/favicon.svg" },
    { "src": "/apontamento/favicon\\.ico", "dest": "/pop/favicon.ico" },
    { "src": "/apontamento/favicon\\.svg", "dest": "/pop/favicon.svg" },
    { "src": "/robots\\.txt", "dest": "/robots.txt" },
    { "src": "/rastreio", "dest": "/apps/rastreio/index.html" },
    { "src": "/rastreio/(.*)", "dest": "/apps/rastreio/index.html" },
    { "src": "/pdv", "dest": "/apps/pdv/index.html" },
    { "src": "/pdv/(.*)", "dest": "/apps/pdv/index.html" },
    { "src": "/ptc", "dest": "/apps/ptc/index.html" },
    { "src": "/ptc/(.*)", "dest": "/apps/ptc/index.html" },
    { "src": "/pas", "dest": "/apps/pas/index.html" },
    { "src": "/pas/(.*)", "dest": "/apps/pas/index.html" },
    { "src": "/apontamento", "dest": "/apps/pop/index.html" },
    { "src": "/apontamento/(.*)", "dest": "/apps/pop/index.html" },
    { "src": "/pop", "dest": "/apps/pop/index.html" },
    { "src": "/pop/(.*)", "dest": "/apps/pop/index.html" },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "rastreio.umoya.omatheus.com" }],
      "dest": "/apps/rastreio/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "pdv.umoya.omatheus.com" }],
      "dest": "/apps/pdv/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "ptc.umoya.omatheus.com" }],
      "dest": "/apps/ptc/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "pas.umoya.omatheus.com" }],
      "dest": "/apps/pas/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "pop.umoya.omatheus.com" }],
      "dest": "/apps/pop/index.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "erp.umoya.omatheus.com" }],
      "dest": "/apps/erp/index.html"
    },
    { "src": "/(.*)", "dest": "/apps/erp/index.html" }
  ]
}
